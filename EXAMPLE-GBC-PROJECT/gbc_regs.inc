; Game Boy / Game Boy Color hardware registers
; RGBDS syntax

; Joypad
DEF rP1    EQU $FF00

; Serial
DEF rSB    EQU $FF01
DEF rSC    EQU $FF02

; Timer
DEF rDIV   EQU $FF04
DEF rTIMA  EQU $FF05
DEF rTMA   EQU $FF06
DEF rTAC   EQU $FF07

; Interrupt flags
DEF rIF    EQU $FF0F
DEF rIE    EQU $FFFF

; Audio
DEF rNR10  EQU $FF10
DEF rNR11  EQU $FF11
DEF rNR12  EQU $FF12
DEF rNR13  EQU $FF13
DEF rNR14  EQU $FF14
DEF rNR21  EQU $FF16
DEF rNR22  EQU $FF17
DEF rNR23  EQU $FF18
DEF rNR24  EQU $FF19
DEF rNR30  EQU $FF1A
DEF rNR31  EQU $FF1B
DEF rNR32  EQU $FF1C
DEF rNR33  EQU $FF1D
DEF rNR34  EQU $FF1E
DEF rNR41  EQU $FF20
DEF rNR42  EQU $FF21
DEF rNR43  EQU $FF22
DEF rNR44  EQU $FF23
DEF rNR50  EQU $FF24
DEF rNR51  EQU $FF25
DEF rNR52  EQU $FF26

; LCD / PPU
DEF rLCDC  EQU $FF40
DEF rSTAT  EQU $FF41
DEF rSCY   EQU $FF42
DEF rSCX   EQU $FF43
DEF rLY    EQU $FF44
DEF rLYC   EQU $FF45
DEF rDMA   EQU $FF46
DEF rBGP   EQU $FF47
DEF rOBP0  EQU $FF48
DEF rOBP1  EQU $FF49
DEF rWY    EQU $FF4A
DEF rWX    EQU $FF4B

; CGB VRAM / DMA
DEF rVBK   EQU $FF4F
DEF rHDMA1 EQU $FF51
DEF rHDMA2 EQU $FF52
DEF rHDMA3 EQU $FF53
DEF rHDMA4 EQU $FF54
DEF rHDMA5 EQU $FF55

; CGB palettes
DEF rBCPS  EQU $FF68
DEF rBCPD  EQU $FF69
DEF rOCPS  EQU $FF6A
DEF rOCPD  EQU $FF6B

; Common aliases
DEF rBGPI  EQU rBCPS
DEF rBGPD  EQU rBCPD
DEF rOBPI  EQU rOCPS
DEF rOBPD  EQU rOCPD

; CGB speed / infrared
DEF rKEY1  EQU $FF4D
DEF rRP    EQU $FF56

; Banking / boot
DEF rSVBK  EQU $FF70
DEF rBOOT  EQU $FF50

; Memory regions
DEF _VRAM      EQU $8000
DEF _SCRN0     EQU $9800
DEF _SCRN1     EQU $9C00
DEF _RAM       EQU $C000
DEF _OAMRAM    EQU $FE00
DEF _HRAM      EQU $FF80

; LCDC flags
DEF LCDCF_ON       EQU %10000000
DEF LCDCF_WIN9800  EQU %00000000
DEF LCDCF_WIN9C00  EQU %01000000
DEF LCDCF_WINON    EQU %00100000
DEF LCDCF_BG8800   EQU %00000000
DEF LCDCF_BG8000   EQU %00010000
DEF LCDCF_BG9800   EQU %00000000
DEF LCDCF_BG9C00   EQU %00001000
DEF LCDCF_OBJ8     EQU %00000000
DEF LCDCF_OBJ16    EQU %00000100
DEF LCDCF_OBJON    EQU %00000010
DEF LCDCF_BGON     EQU %00000001

; STAT flags
DEF STATF_LYC       EQU %01000000
DEF STATF_MODE10    EQU %00100000
DEF STATF_MODE01    EQU %00010000
DEF STATF_MODE00    EQU %00001000
DEF STATF_LYCF      EQU %00000100

; Interrupt flags
DEF IEF_VBLANK  EQU %00000001
DEF IEF_STAT    EQU %00000010
DEF IEF_TIMER   EQU %00000100
DEF IEF_SERIAL  EQU %00001000
DEF IEF_JOYPAD  EQU %00010000

; Joypad select bits
DEF P1F_GET_DPAD    EQU %00100000
DEF P1F_GET_BTN     EQU %00010000

; Joypad input bits, after reading rP1
; Pressed = 0
DEF PADF_RIGHT  EQU %00000001
DEF PADF_LEFT   EQU %00000010
DEF PADF_UP     EQU %00000100
DEF PADF_DOWN   EQU %00001000
DEF PADF_A      EQU %00000001
DEF PADF_B      EQU %00000010
DEF PADF_SELECT EQU %00000100
DEF PADF_START  EQU %00001000

; Sprite attribute flags
DEF OAMF_PAL1   EQU %00010000
DEF OAMF_BANK1  EQU %00001000
DEF OAMF_XFLIP  EQU %00100000
DEF OAMF_YFLIP  EQU %01000000
DEF OAMF_PRI    EQU %10000000
